DATABASE_URL=postgresql+psycopg://nmkgn:nmkgn@localhost:55432/nmkgn
NMKGN_STUB_OWNER_REF=demo-user
NMKGN_CORS_ORIGINS=http://localhost:15179,http://127.0.0.1:15179

# Frontend API base URL (Vite injects at build time via src/api/client.ts).
# Omit to use the default http://localhost:18080.
VITE_API_BASE_URL=http://localhost:18080

# Local-only document upload storage. Do not enable production uploads until
# auth, malware scanning, backup/restore, retention, and audit policy are set.
NMKGN_UPLOAD_STORAGE_DIR=var/uploads
NMKGN_UPLOAD_MAX_BYTES=26214400
NMKGN_UPLOAD_RETENTION_DAYS=30
NMKGN_UPLOAD_ALLOWED_CONTENT_TYPES=application/pdf,text/plain,image/jpeg,image/png
NMKGN_ENABLE_PRODUCTION_UPLOADS=false

# DocumentReceptionistAgent gate. The fake provider is deterministic and intended
# for local development/tests; external providers should fail closed when unset.
NMKGN_RECEPTIONIST_ENABLED=true
NMKGN_RECEPTIONIST_PROVIDER=fake
NMKGN_RECEPTIONIST_MODEL=fake-receptionist-v1
NMKGN_RECEPTIONIST_MAX_PAGES=12
NMKGN_RECEPTIONIST_TIMEOUT_SECONDS=30

# Manual-only ConsumerCreditBaselineAgent harness. The default local-replay
# provider reads manual-test-cases/baselines.local/<case-id>/baseline.json.
# Anthropic runs also require ANTHROPIC_API_KEY and --allow-external-llm.
NMKGN_BASELINE_PROVIDER=local-replay
NMKGN_BASELINE_MODEL=claude-sonnet-4-5
NMKGN_BASELINE_MAX_PAGES=12
